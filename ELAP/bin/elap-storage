#!/bin/bash
# ELAP Storage Component
# Manages LVM storage, disk health, backups, and snapshots
# Usage: elap storage [--report] [--expand] [--backup] [--snapshot LV]

set -euo pipefail
IFS=$'\n\t'

# shellcheck disable=SC1091
# shellcheck source=../lib/common.sh
source "$(dirname "${BASH_SOURCE[0]}")/../lib/common.sh"
export ELAP_COMPONENT="elap-storage"

# ── Parse arguments ───────────────────────────────────────────
MODE="report"
SNAPSHOT_LV=""

while [[ $# -gt 0 ]]; do
    case "$1" in
        --report)   MODE="report";   shift ;;
        --expand)   MODE="expand";   shift ;;
        --backup)   MODE="backup";   shift ;;
        --snapshot) MODE="snapshot"
                    SNAPSHOT_LV="${2:-}"
                    shift 2 ;;
        --help)
            echo "Usage: elap storage [--report|--expand|--backup|--snapshot LV]"
            exit 0 ;;
        *) log_error "Unknown option: $1"; exit 1 ;;
    esac
done

elap_acquire_lock "elap-storage"

# ── Load configuration ────────────────────────────────────────
EXPAND_THRESHOLD="${ELAP_LVM_EXPAND_THRESHOLD:-80}"
EXPAND_BY_GB="${ELAP_LVM_EXPAND_BY_GB:-20}"
BACKUP_ROOT="${ELAP_BACKUP_ROOT:-/backup}"
BACKUP_RETENTION="${ELAP_BACKUP_RETENTION_DAYS:-30}"
mapfile -t BACKUP_DIRS < <(echo "${ELAP_BACKUP_DIRS:-/etc /opt/enterprise-linux-platform}" | tr ' ' '\n')
SNAPSHOT_SIZE_GB="${ELAP_SNAPSHOT_SIZE_GB:-10}"

# ── Storage health report ─────────────────────────────────────
storage_report() {
    elap_section "Filesystem Usage"

    while IFS= read -r line; do
        local mount pct size fstype
        mount=$(echo "$line"  | awk '{print $6}')
        pct=$(echo "$line"    | awk '{print $5}' | tr -d '%')
        size=$(echo "$line"   | awk '{print $2}')
        fstype=$(echo "$line" | awk '{print $1}')
        [[ -z "${pct:-}" ]] && continue

        if   [[ ${pct} -ge 90 ]]; then
            log_error "CRITICAL $mount ($fstype): ${pct}% of $size"
        elif [[ ${pct} -ge 80 ]]; then
            log_warn  "WARNING  $mount ($fstype): ${pct}% of $size"
        else
            log_pass  "OK       $mount ($fstype): ${pct}% of $size"
        fi
    done < <(df -hT | grep -vE "tmpfs|devtmpfs|Filesystem")

    elap_section "Inode Usage"
    df -ih | grep -vE "tmpfs|devtmpfs|Filesystem" | \
        awk '{pct=$5+0; if(pct>70)
              printf "  WARNING %s: %s inodes used\n", $6, $5}'

    elap_section "LVM Layout"
    if command -v pvs &>/dev/null; then
        echo "Physical Volumes:"
        pvs --noheadings -o pv_name,pv_size,pv_free,vg_name 2>/dev/null | \
            awk '{printf "  %-20s Size:%-8s Free:%-8s VG:%s\n",
                 $1,$2,$3,$4}'
        echo ""
        echo "Volume Groups:"
        vgs --noheadings -o vg_name,vg_size,vg_free 2>/dev/null | \
            awk '{printf "  %-15s Size:%-8s Free:%s\n",$1,$2,$3}'
        echo ""
        echo "Logical Volumes:"
        lvs --noheadings -o lv_path,lv_size,lv_attr 2>/dev/null | \
            awk '{printf "  %-35s Size:%s\n",$1,$2}'
    else
        log_info "LVM not available on this system"
    fi

    elap_section "Disk Errors"
    local errors
    errors=$(dmesg 2>/dev/null | \
        grep -iE "I/O error|hardware error|disk error" | wc -l)
    [[ "${errors:-0}" -gt 0 ]] && \
        log_error "$errors disk error(s) in kernel log" || \
        log_pass "No disk errors in kernel log"

    elap_section "Deleted Files Still Consuming Space"
    local held_open
    held_open=$(lsof 2>/dev/null | grep "(deleted)" | wc -l)
    [[ "${held_open:-0}" -gt 0 ]] && \
        log_warn "$held_open deleted file(s) still held open by processes" || \
        log_pass "No deleted files held open"
}

# ── Auto-expand LVM volumes ───────────────────────────────────
auto_expand() {
    log_info "Checking volumes for auto-expansion (threshold: ${EXPAND_THRESHOLD}%)"

    local expanded=0

    while IFS= read -r line; do
        local mount pct source lv_path fs_type vg_name vg_free_gb

        mount=$(echo "$line" | awk '{print $6}')
        pct=$(echo "$line"   | awk '{print $5}' | tr -d '%')
        [[ "${pct:-0}" -lt "$EXPAND_THRESHOLD" ]] && continue

        # Is this mount point backed by an LV?
        source=$(findmnt -n -o SOURCE "$mount" 2>/dev/null || echo "")
        [[ -z "$source" ]] && continue
        lvs "$source" &>/dev/null 2>&1 || continue

        vg_name=$(lvs --noheadings -o vg_name "$source" \
                  2>/dev/null | tr -d ' ')
        fs_type=$(findmnt -n -o FSTYPE "$mount" 2>/dev/null)

        # Check VG has enough free space:
        vg_free_gb=$(vgs --noheadings --units g -o vg_free \
                     "$vg_name" 2>/dev/null | tr -d ' g')

        if (( $(echo "${vg_free_gb:-0} < $EXPAND_BY_GB" | bc -l) )); then
            log_warn "$mount at ${pct}% but VG has only ${vg_free_gb}GB free"
            continue
        fi

        log_info "Expanding $source at $mount (${pct}% full)"
        elap_run lvextend -L "+${EXPAND_BY_GB}G" "$source"

        case "$fs_type" in
            xfs)  elap_run xfs_growfs "$mount" ;;
            ext4|ext3) elap_run resize2fs "$source" ;;
            *)    log_warn "Unknown filesystem $fs_type — manual resize needed"
                  continue ;;
        esac

        log_apply "Expanded $mount by ${EXPAND_BY_GB}GB"
        ((expanded++))
    done < <(df -h | grep -vE "tmpfs|devtmpfs|Filesystem")

    [[ $expanded -eq 0 ]] && \
        log_info "No volumes required expansion" || \
        log_info "Expanded $expanded volume(s)"
}

# ── Backup with verification ──────────────────────────────────
run_backup() {
    log_info "Starting backup run"
    log_info "Backup root: $BACKUP_ROOT"
    mkdir -p "$BACKUP_ROOT"

    local success=0 failed=0
    local timestamp
    timestamp=$(date +%Y%m%d-%H%M%S)

    for source_dir in "${BACKUP_DIRS[@]}"; do
        [[ -d "$source_dir" ]] || {
            log_warn "Backup source not found: $source_dir (skipping)"
            continue
        }

        local dir_name
        dir_name=$(echo "$source_dir" | tr '/' '_' | sed 's/^_//')
        local backup_file="${BACKUP_ROOT}/${dir_name}_${timestamp}.tar.gz"
        local checksum_file="${backup_file}.sha256"

        log_info "Backing up: $source_dir"

        if elap_run tar czf "$backup_file" \
            --exclude="*.pyc" \
            --exclude="__pycache__" \
            --exclude=".git" \
            "$source_dir" 2>/dev/null; then

            sha256sum "$backup_file" > "$checksum_file"
            local size
            size=$(du -sh "$backup_file" | cut -f1)
            log_apply "Backup created: $(basename $backup_file) ($size)"
            ((success++))
        else
            log_error "Backup FAILED: $source_dir"
            rm -f "$backup_file"
            ((failed++))
        fi
    done

    # Retention cleanup:
    log_info "Applying retention: ${BACKUP_RETENTION} days"
    local removed=0
    while IFS= read -r old_file; do
        elap_run rm -f "$old_file" "${old_file}.sha256"
        log_info "Removed old backup: $(basename $old_file)"
        ((removed++))
    done < <(find "$BACKUP_ROOT" -name "*.tar.gz" \
        -mtime +"$BACKUP_RETENTION" 2>/dev/null)

    log_info "Backup complete: $success succeeded, $failed failed, $removed old removed"

    [[ $failed -gt 0 ]] && \
        elap_notify "ERROR" "Backup: $failed failure(s) on $(hostname -s)" || \
        elap_notify "SUCCESS" "Backup: $success archive(s) on $(hostname -s)"

    [[ $failed -gt 0 ]] && return 1 || return 0
}

# ── LVM snapshot ──────────────────────────────────────────────
create_snapshot() {
    local lv_path="$1"
    [[ -z "$lv_path" ]] && {
        log_error "--snapshot requires a logical volume path (e.g. /dev/vg0/lv_data)"
        exit 1
    }

    lvs "$lv_path" &>/dev/null || {
        log_error "Logical volume not found: $lv_path"
        exit 1
    }

    local snap_name
    snap_name="$(basename $lv_path)_snap_$(date +%Y%m%d_%H%M%S)"
    local vg_name
    vg_name=$(lvs --noheadings -o vg_name "$lv_path" | tr -d ' ')

    log_info "Creating snapshot: $snap_name from $lv_path"
    elap_run lvcreate -L "${SNAPSHOT_SIZE_GB}G" -s \
        -n "$snap_name" "$lv_path"

    log_apply "Snapshot created: /dev/${vg_name}/${snap_name}"
    log_info "Mount with: mount -o ro /dev/${vg_name}/${snap_name} /mnt/snap"
    log_info "Remove with: lvremove /dev/${vg_name}/${snap_name}"
}

# ── Dispatch ──────────────────────────────────────────────────
case "$MODE" in
    report)   storage_report ;;
    expand)   elap_require_root; auto_expand ;;
    backup)   run_backup ;;
    snapshot) elap_require_root; create_snapshot "$SNAPSHOT_LV" ;;
esac